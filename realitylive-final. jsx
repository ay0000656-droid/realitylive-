// ─── SHOW DETAIL MODAL ────────────────────────────────────────────────────────
function ShowDetail({ show, user, onClose, onToast, onBuyVotes }) {
  const [votes, setVotes] = useState([...show.votes]);
  const [voted, setVoted] = useState(null);
  const [chat, setChat] = useState([...SEED_CHAT]);
  const [msg, setMsg] = useState("");
  const { status, watchStream, stopAll } = useAgora();
  const [watching, setWatching] = useState(false);
  const [showReport, setShowReport] = useState(false);
  const [reportReason, setReportReason] = useState("");
  const [reported, setReported] = useState(false);

  async function submitReport() {
    if (!reportReason) return;
    await fbSaveReport(user.uid || "anon", show.id, reportReason).catch(console.error);
    setReported(true);
    setShowReport(false);
    onToast("Report submitted. We review all reports within 24 hours.");
  }

  const total = votes.reduce((a,b) => a+b, 0);
  const agoraReady = AGORA_APP_ID !== "YOUR_AGORA_APP_ID";
  const channel = "rl_" + show.title.replace(/\s+/g,"_").toLowerCase();

  async function toggleWatch() {
    if (watching) { await stopAll(); setWatching(false); }
    else { await watchStream(channel); setWatching(true); }
  }
  function vote(i) {
    if (voted !== null) return;
    if (user.voteCredits < 1) { onBuyVotes(); return; }
    const nv = [...votes]; nv[i] += 1;
    setVotes(nv); setVoted(i);
    user.voteCredits -= 1;
    onToast(`Voted for ${show.contestants[i]}! (${user.voteCredits} votes left)`);
    // Save vote to Firestore if Firebase is configured
    if (user.uid) fbCastVote(user.uid, show.id, i).catch(console.error);
  }

  function sendChat() {
    if (!msg.trim()) return;
    setChat(p => [{ user:user.name, text:msg.trim(), ts:"just now" }, ...p]);
    setMsg("");
  }

  return (
    <div className="modal-bg">
      <div className="card" style={{ width:"min(740px,96vw)", maxHeight:"92vh", overflow:"hidden", display:"flex", flexDirection:"column" }}>
        {/* Header */}
        <div style={{ padding:"15px 20px", borderBottom:`1px solid ${T.border}`, display:"flex", justifyContent:"space-between", alignItems:"center", flexShrink:0 }}>
          <div style={{ display:"flex", alignItems:"center", gap:10 }}>
            <span style={{ fontSize:22 }}>{show.emoji}</span>
            <div>
              <div className="syne" style={{ fontSize:18, color:T.white }}>{show.title}</div>
              <div style={{ fontSize:12, color:T.muted }}>by {show.host} · 👁 {fmt(show.viewers)} watching</div>
            </div>
          </div>
          <div style={{ display:"flex", gap:8 }}>
            {!reported && (
              <button onClick={() => setShowReport(p => !p)} style={{
                padding:"5px 11px", fontSize:12, borderRadius:7,
                background:"rgba(232,54,93,0.1)", border:"1px solid rgba(232,54,93,0.3)",
                color:T.accent, cursor:"pointer", fontFamily:"Space Grotesk", fontWeight:600
              }}>⚑ Report</button>
            )}
            <button className="btn-ghost" onClick={onClose} style={{ padding:"5px 11px", fontSize:13 }}>✕</button>
          </div>
        </div>

        {/* Report panel */}
        {showReport && (
          <div style={{ padding:"14px 20px", background:"rgba(232,54,93,0.06)", borderBottom:`1px solid ${T.border}`, flexShrink:0 }}>
            <div style={{ fontSize:13, fontWeight:600, color:T.text, marginBottom:10 }}>Why are you reporting this stream?</div>
            <div style={{ display:"flex", flexWrap:"wrap", gap:8, marginBottom:10 }}>
              {["Nudity / sexual content","Violence or harm","Hate speech","Spam or scam","Underage content","Other"].map(r => (
                <button key={r} onClick={() => setReportReason(r)} style={{
                  padding:"6px 12px", borderRadius:20, fontSize:12, fontWeight:600,
                  border:`1px solid ${reportReason===r ? T.accent : T.border}`,
                  background: reportReason===r ? T.accentLo : "transparent",
                  color: reportReason===r ? T.accent : T.muted,
                  cursor:"pointer", fontFamily:"Space Grotesk"
                }}>{r}</button>
              ))}
            </div>
            <div style={{ display:"flex", gap:8 }}>
              <button onClick={submitReport} disabled={!reportReason} style={{
                padding:"8px 16px", borderRadius:7, fontSize:13, fontWeight:700,
                background:T.accent, color:"#fff", border:"none",
                cursor: reportReason ? "pointer" : "not-allowed", opacity: reportReason ? 1 : 0.5,
                fontFamily:"Space Grotesk"
              }}>Submit Report</button>
              <button onClick={() => setShowReport(false)} className="btn-ghost" style={{ padding:"8px 14px", fontSize:13 }}>Cancel</button>
            </div>
          </div>
        )}

        <div style={{ display:"flex", overflow:"hidden", flex:1 }}>
          {/* Left: stream + voting */}
          <div style={{ flex:1, overflowY:"auto", padding:18, display:"flex", flexDirection:"column", gap:16 }}>
            {/* Stream area */}
            <div style={{ height:180, position:"relative" }}>
              {agoraReady && watching && status==="watching"
                ? <div id="agora-remote" style={{ width:"100%", height:"100%" }} />
                : (
                  <div className="stream-bg" style={{ height:180 }}>
                    <div style={{ fontSize:36 }}>{show.emoji}</div>
                    <div style={{ color:show.color, fontWeight:700, fontSize:14 }}>
                      {agoraReady ? (watching ? "Connecting..." : "Click Watch to join live") : "DEMO — Add Agora App ID to watch live"}
                    </div>
                    <div style={{ display:"flex", gap:6, alignItems:"center", background:"rgba(0,0,0,0.6)", padding:"4px 10px", borderRadius:99, zIndex:1 }}>
                      <span className="live-dot" />
                      <span style={{ fontSize:12, color:"#fff" }}>{fmt(show.viewers)} watching</span>
                    </div>
                  </div>
                )
              }
              <button onClick={toggleWatch} style={{
                position:"absolute", bottom:10, right:10,
                background:"rgba(0,0,0,0.75)", border:`1px solid ${T.border}`,
                borderRadius:7, color:T.text, fontFamily:"Space Grotesk",
                fontSize:12, fontWeight:600, padding:"6px 12px", cursor:"pointer"
              }}>
                {watching ? "⏹ Stop" : "▶ Watch Live"}
              </button>
            </div>

            {/* Voting */}
            <div>
              <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:12 }}>
                <div style={{ fontSize:12, color:T.muted, fontWeight:600, letterSpacing:"0.07em" }}>
                  🗳️ VOTE · {fmt(total)} total
                </div>
                <button onClick={onBuyVotes} style={{
                  fontSize:11, color:T.accent, fontWeight:700,
                  background:T.accentLo, border:`1px solid ${T.accent}44`,
                  borderRadius:6, padding:"4px 10px", cursor:"pointer", fontFamily:"Space Grotesk"
                }}>
                  + Buy Votes ({user.voteCredits || 0} left)
                </button>
              </div>

              <div style={{ display:"flex", flexDirection:"column", gap:10 }}>
                {show.contestants.map((name,i) => {
                  const pct = Math.round((votes[i]/total)*100);
                  const leading = votes[i] === Math.max(...votes);
                  return (
                    <div key={i} style={{ display:"flex", alignItems:"center", gap:10 }}>
                      <div className="avatar" style={{ width:32, height:32, background:show.color+"33", color:show.color, fontSize:12 }}>
                        {name[0]}
                      </div>
                      <div style={{ flex:1 }}>
                        <div style={{ display:"flex", justifyContent:"space-between", marginBottom:4 }}>
                          <span style={{ fontSize:13, fontWeight:600, color: leading ? T.white : T.text }}>
                            {name} {leading && "👑"}
                          </span>
                          <span style={{ fontSize:13, color:show.color, fontWeight:700 }}>{pct}%</span>
                        </div>
                        <div className="vbar-bg">
                          <div className="vbar-fill" style={{ width:`${pct}%`, background:show.color }} />
                        </div>
                      </div>
                      <button onClick={() => vote(i)} disabled={voted!==null}
                        style={{ padding:"6px 11px", borderRadius:6,
                          border:`1px solid ${voted===i ? show.color : T.border}`,
                          background: voted===i ? show.color+"33" : "transparent",
                          color: voted===i ? show.color : T.muted,
                          cursor: voted===null ? "pointer" : "default",
                          fontSize:12, fontWeight:700, fontFamily:"Space Grotesk", minWidth:52, transition:"all 0.15s"
                        }}>
                        {voted===i ? "✓" : "Vote"}
                      </button>
                    </div>
                  );
                })}
              </div>

              {voted===null && (
                <p style={{ fontSize:12, color:T.muted, marginTop:10, textAlign:"center" }}>
                  No votes yet? <button onClick={onBuyVotes} style={{ color:T.accent, background:"none", border:"none", cursor:"pointer", fontSize:12, fontWeight:700 }}>Buy a vote pack to join →</button>
                </p>
              )}
            </div>
          </div>

          {/* Right: chat */}
          <div className="hide-sm" style={{ width:215, borderLeft:`1px solid ${T.border}`, display:"flex", flexDirection:"column" }}>
            <div style={{ padding:"11px 14px", fontSize:11, color:T.muted, fontWeight:700, borderBottom:`1px solid ${T.border}`, letterSpacing:"0.08em" }}>
              💬 LIVE CHAT
            </div>
            <div style={{ flex:1, overflowY:"auto", padding:10, display:"flex", flexDirection:"column", gap:7 }}>
              {chat.map((c,i) => (
                <div key={i} className="bubble">
                  <span style={{ color:show.color, fontWeight:700, fontSize:12 }}>{c.user} </span>
                  <span style={{ color:T.text }}>{c.text}</span>
                </div>
              ))}
            </div>
            <div style={{ padding:8, borderTop:`1px solid ${T.border}`, display:"flex", gap:6 }}>
              <input value={msg} onChange={e => setMsg(e.target.value)}
                onKeyDown={e => e.key==="Enter" && sendChat()}
                placeholder="Chat..." style={{ fontSize:12, padding:"7px 10px" }} />
              <button className="btn-primary" onClick={sendChat} style={{ padding:"7px 10px", fontSize:13, borderRadius:6 }}>↑</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}

